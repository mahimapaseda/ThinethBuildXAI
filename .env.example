# ─── Backend (server/index.js) ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated allowed origins (production). Leave empty for dev (allows localhost).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin: only this email can become admin when registering with the secret below
ADMIN_EMAIL=you@example.com
ADMIN_SECRET=change-me-admin-setup-secret

# ─── Frontend (Vite — optional dev convenience, prefix VITE_) ────────────────
# Users normally enter their key in the app UI. Do not commit real keys.
VITE_API_URL=/api
# VITE_GEMINI_API_KEY=AIza...
