# BuildX AI — Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Google Gemini API key (get from aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: JWT secret for auth tokens (auto-generated on Render)
JWT_SECRET=your_jwt_secret_here

# Optional: Server port (defaults to 3001 locally, 10000 on Render)
PORT=3001
